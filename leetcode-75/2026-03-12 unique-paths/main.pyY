import math

# Approach: Use the combinatorics formula for grid paths: choose (m-1) downs among (m+n-2) moves.
# Time Complexity: O(m + n)
# Space Complexity: O(1)
# Edge Cases: m = 1, n = 1, very rectangular grids

class Solution:
    def uniquePaths(self, m: int, n: int) -> int:
        return math.factorial(m + n - 2) // (math.factorial(m - 1) * math.factorial(n - 1))
